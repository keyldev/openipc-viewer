<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <uses-sdk android:minSdkVersion="31" android:targetSdkVersion="36" />

  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

  <!-- Phase 9c — recording. FOREGROUND_SERVICE_DATA_SYNC required from
       Android 14 (API 34) onward to declare the service type explicitly.
       POST_NOTIFICATIONS is the runtime permission gating the recording
       notification on Android 13+ — first record attempt triggers a prompt. -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

  <application android:label="@string/app_name"
               android:icon="@mipmap/icon"
               android:roundIcon="@mipmap/icon"
               android:allowBackup="true"
               android:supportsRtl="true">
  </application>
</manifest>
