<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenIPC.Viewer.App.ViewModels"
             x:Class="OpenIPC.Viewer.App.Views.BottomNavBar"
             x:DataType="vm:MainWindowViewModel"
             Background="{StaticResource Bg2Brush}">

  <Border BorderBrush="{StaticResource BorderWeakBrush}"
          BorderThickness="0,1,0,0"
          Padding="8,4">

    <UniformGrid Rows="1" Columns="5">

      <RadioButton Classes="bottomnav" GroupName="MobileNav"
                   IsChecked="{Binding IsLiveSelected, Mode=OneWay}"
                   Command="{Binding NavigateCommand}"
                   CommandParameter="live">
        <StackPanel Spacing="3" HorizontalAlignment="Center">
          <PathIcon Data="{StaticResource IconLive}" Width="18" Height="18" HorizontalAlignment="Center" />
          <TextBlock Text="Live" HorizontalAlignment="Center" />
        </StackPanel>
      </RadioButton>
      <RadioButton Classes="bottomnav" GroupName="MobileNav"
                   IsChecked="{Binding IsLibrarySelected, Mode=OneWay}"
                   Command="{Binding NavigateCommand}"
                   CommandParameter="library">
        <StackPanel Spacing="3" HorizontalAlignment="Center">
          <PathIcon Data="{StaticResource IconLibrary}" Width="18" Height="18" HorizontalAlignment="Center" />
          <TextBlock Text="Library" HorizontalAlignment="Center" />
        </StackPanel>
      </RadioButton>
      <RadioButton Classes="bottomnav" GroupName="MobileNav"
                   IsChecked="{Binding IsRecordingsSelected, Mode=OneWay}"
                   Command="{Binding NavigateCommand}"
                   CommandParameter="recordings">
        <StackPanel Spacing="3" HorizontalAlignment="Center">
          <PathIcon Data="{StaticResource IconRecordings}" Width="18" Height="18" HorizontalAlignment="Center" />
          <TextBlock Text="Records" HorizontalAlignment="Center" />
        </StackPanel>
      </RadioButton>
      <RadioButton Classes="bottomnav" GroupName="MobileNav"
                   IsChecked="{Binding IsEventsSelected, Mode=OneWay}"
                   Command="{Binding NavigateCommand}"
                   CommandParameter="events">
        <StackPanel Spacing="3" HorizontalAlignment="Center">
          <PathIcon Data="{StaticResource IconEvents}" Width="18" Height="18" HorizontalAlignment="Center" />
          <TextBlock Text="Events" HorizontalAlignment="Center" />
        </StackPanel>
      </RadioButton>
      <RadioButton Classes="bottomnav" GroupName="MobileNav"
                   IsChecked="{Binding IsSettingsSelected, Mode=OneWay}"
                   Command="{Binding NavigateCommand}"
                   CommandParameter="settings">
        <StackPanel Spacing="3" HorizontalAlignment="Center">
          <PathIcon Data="{StaticResource IconSettings}" Width="18" Height="18" HorizontalAlignment="Center" />
          <TextBlock Text="Settings" HorizontalAlignment="Center" />
        </StackPanel>
      </RadioButton>

    </UniformGrid>

  </Border>

</UserControl>
