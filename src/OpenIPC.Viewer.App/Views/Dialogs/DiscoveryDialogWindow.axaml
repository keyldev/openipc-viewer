<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenIPC.Viewer.App.ViewModels.Dialogs"
        xmlns:svc="using:OpenIPC.Viewer.App.Services"
        xmlns:dialogs="using:OpenIPC.Viewer.App.Views.Dialogs"
        x:Class="OpenIPC.Viewer.App.Views.Dialogs.DiscoveryDialogWindow"
        x:DataType="vm:DiscoveryDialogViewModel"
        Title="{Binding [Discovery.Title], Source={x:Static svc:Localizer.Instance}}"
        Width="560" Height="620"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource Bg1Brush}">

  <dialogs:DiscoveryDialogContent Name="InnerContent" />

</Window>
