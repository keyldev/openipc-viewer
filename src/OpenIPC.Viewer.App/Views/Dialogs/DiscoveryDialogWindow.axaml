<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenIPC.Viewer.App.ViewModels.Dialogs"
        x:Class="OpenIPC.Viewer.App.Views.Dialogs.DiscoveryDialogWindow"
        x:DataType="vm:DiscoveryDialogViewModel"
        Title="Discover cameras"
        Width="560" Height="620"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource Bg1Brush}"
        FontFamily="{StaticResource FontSans}"
        FontSize="{StaticResource FontSizeBase}"
        Foreground="{StaticResource TextPrimaryBrush}">

  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="24">

    <!-- Header + scan button -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
      <StackPanel Grid.Column="0" Spacing="4">
        <TextBlock Text="Discover ONVIF cameras"
                   FontSize="{StaticResource FontSizeLg}"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding StatusText}"
                   FontSize="{StaticResource FontSizeSm}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              Content="Scan"
              Command="{Binding ScanCommand}"
              Padding="14,8"
              Background="{StaticResource AccentBrush}"
              Foreground="White"
              CornerRadius="6"
              VerticalAlignment="Top" />
    </Grid>

    <!-- Discovered list -->
    <Border Grid.Row="1"
            Background="{StaticResource Bg2Brush}"
            BorderBrush="{StaticResource BorderWeakBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="2">
      <ListBox ItemsSource="{Binding Cameras}"
               SelectedItem="{Binding Selected, Mode=TwoWay}"
               Background="Transparent"
               BorderThickness="0">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:DiscoveredCameraRowVm">
            <Grid ColumnDefinitions="*,Auto" Margin="8">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="{Binding DisplayName}"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding Subtitle}"
                           FontSize="{StaticResource FontSizeSm}"
                           Foreground="{StaticResource TextSecondaryBrush}" />
              </StackPanel>
              <TextBlock Grid.Column="1"
                         Text="{Binding HostPort}"
                         FontFamily="{StaticResource FontMono}"
                         FontSize="{StaticResource FontSizeSm}"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <!-- Credentials -->
    <Grid Grid.Row="2" ColumnDefinitions="*,12,*" Margin="0,16,0,0"
          IsVisible="{Binding IsRowSelected}">
      <StackPanel Grid.Column="0" Spacing="6">
        <TextBlock Text="Username" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSm}" />
        <TextBox Text="{Binding Username, Mode=TwoWay}" PlaceholderText="admin" />
      </StackPanel>
      <StackPanel Grid.Column="2" Spacing="6">
        <TextBlock Text="Password" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSm}" />
        <TextBox Text="{Binding Password, Mode=TwoWay}" PasswordChar="•" />
      </StackPanel>
    </Grid>

    <!-- Buttons -->
    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" Margin="0,16,0,0">
      <Button Grid.Column="1"
              Name="CancelButton"
              Content="Cancel"
              Padding="14,8"
              Background="Transparent"
              BorderBrush="{StaticResource BorderMediumBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Foreground="{StaticResource TextPrimaryBrush}"
              Margin="0,0,8,0" />
      <Button Grid.Column="2"
              Name="AddButton"
              Content="Add selected"
              IsEnabled="{Binding CanAdd}"
              Padding="14,8"
              Background="{StaticResource AccentBrush}"
              Foreground="White"
              CornerRadius="6"
              IsDefault="True" />
    </Grid>

  </Grid>

</Window>
