<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="using:OpenIPC.Viewer.App.Services"
        x:Class="OpenIPC.Viewer.App.Views.Dialogs.RawConfigEditorDialog"
        Title="{Binding [RawConfigEditor.Title], Source={x:Static svc:Localizer.Instance}}"
        Width="780" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg1Brush}"
        FontFamily="{StaticResource FontSans}"
        FontSize="{StaticResource FontSizeBase}"
        Foreground="{StaticResource TextPrimaryBrush}">

  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="20">

    <TextBlock Grid.Row="0"
               Text="{Binding [RawConfigEditor.Title], Source={x:Static svc:Localizer.Instance}}"
               FontSize="{StaticResource FontSizeLg}"
               FontWeight="SemiBold"
               Margin="0,0,0,8" />

    <Border Grid.Row="1"
            Background="{StaticResource Bg0Brush}"
            BorderBrush="{StaticResource BorderWeakBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="2">
      <TextBox Name="Editor"
               AcceptsReturn="True"
               AcceptsTab="True"
               TextWrapping="NoWrap"
               FontFamily="{StaticResource FontMono}"
               FontSize="12"
               Background="Transparent"
               BorderThickness="0"
               Foreground="{StaticResource TextPrimaryBrush}"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               ScrollViewer.VerticalScrollBarVisibility="Auto" />
    </Border>

    <TextBlock Grid.Row="2"
               Name="ErrorBlock"
               Foreground="{StaticResource DangerBrush}"
               FontSize="{StaticResource FontSizeSm}"
               Margin="0,8,0,0"
               IsVisible="False"
               TextWrapping="Wrap" />

    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
      <Button Grid.Column="1"
              Name="CancelButton"
              Content="{Binding [Common.Cancel], Source={x:Static svc:Localizer.Instance}}"
              Padding="14,8"
              Background="Transparent"
              BorderBrush="{StaticResource BorderMediumBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Foreground="{StaticResource TextPrimaryBrush}"
              Margin="0,0,8,0" />
      <Button Grid.Column="2"
              Name="ApplyButton"
              Content="{Binding [Common.Apply], Source={x:Static svc:Localizer.Instance}}"
              Padding="14,8"
              Background="{StaticResource AccentBrush}"
              Foreground="White"
              CornerRadius="6"
              IsDefault="True" />
    </Grid>

  </Grid>

</Window>
