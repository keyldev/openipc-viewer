<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="using:OpenIPC.Viewer.App.Services"
        xmlns:dialogs="using:OpenIPC.Viewer.App.Views.Dialogs"
        x:Class="OpenIPC.Viewer.App.Views.Dialogs.WelcomeDialog"
        Title="{Binding [Welcome.WindowTitle], Source={x:Static svc:Localizer.Instance}}"
        Width="480" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource Bg1Brush}">

  <dialogs:WelcomeDialogContent Name="InnerContent" />

</Window>
