<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="using:OpenIPC.Viewer.App.Services"
             xmlns:conv="using:OpenIPC.Viewer.App.Converters"
             x:Class="OpenIPC.Viewer.App.Views.Dialogs.WelcomeDialogContent"
             MaxWidth="480"
             Background="{StaticResource Bg1Brush}"
             FontFamily="{StaticResource FontSans}"
             FontSize="{StaticResource FontSizeBase}"
             Foreground="{StaticResource TextPrimaryBrush}">

  <!-- Margin 32 (not the 24-px dialog standard) — welcome screen with four
       full-width action buttons gets more breathing room on purpose. -->
  <StackPanel Spacing="16" Margin="32" VerticalAlignment="Center">

    <StackPanel Orientation="Horizontal" Spacing="12">
      <Image Source="/Assets/openipc-logo.png" Width="40" Height="40" />
      <StackPanel VerticalAlignment="Center">
        <TextBlock Text="{Binding [Welcome.Title], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeLg}"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding [Welcome.Tagline], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeSm}"
                   Foreground="{StaticResource TextSecondaryBrush}" />
      </StackPanel>
    </StackPanel>

    <TextBlock Text="{Binding [Welcome.Lead], Source={x:Static svc:Localizer.Instance}}"
               Foreground="{StaticResource TextSecondaryBrush}"
               Margin="0,8,0,0" />

    <Button Name="DiscoverButton"
            Content="{Binding [Welcome.Discover], Source={x:Static svc:Localizer.Instance}}"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Left"
            Padding="14,12"
            Background="{StaticResource AccentBrush}"
            Foreground="White"
            CornerRadius="8" />

    <Button Name="ScanQrButton"
            Content="{Binding [Welcome.ScanQr], Source={x:Static svc:Localizer.Instance}}"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Left"
            Padding="14,12"
            Background="Transparent"
            BorderBrush="{StaticResource BorderMediumBrush}"
            BorderThickness="1"
            CornerRadius="8" />

    <Button Name="AddManuallyButton"
            Content="{Binding [Welcome.AddManually], Source={x:Static svc:Localizer.Instance}}"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Left"
            Padding="14,12"
            Background="Transparent"
            BorderBrush="{StaticResource BorderMediumBrush}"
            BorderThickness="1"
            CornerRadius="8" />

    <Button Name="SkipButton"
            Content="{Binding [Welcome.Skip], Source={x:Static svc:Localizer.Instance}}"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Left"
            Padding="14,12"
            Background="Transparent"
            Foreground="{StaticResource TextSecondaryBrush}"
            BorderThickness="0" />

    <!-- Language picker — quiet footer row. Surfaces here too so users on a
         non-default system locale can flip languages before adding their
         first camera, not just from Settings. -->
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right"
                Margin="0,4,0,0" VerticalAlignment="Center">
      <TextBlock Text="{Binding [Welcome.Language], Source={x:Static svc:Localizer.Instance}}"
                 Foreground="{StaticResource TextTertiaryBrush}"
                 FontSize="{StaticResource FontSizeSm}"
                 VerticalAlignment="Center" />
      <ComboBox Name="LanguagePicker" MinWidth="140">
        <ComboBox.Items>
          <x:String>system</x:String>
          <x:String>en</x:String>
          <x:String>ru</x:String>
        </ComboBox.Items>
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="x:String">
            <TextBlock Text="{Binding ., Converter={x:Static conv:LanguageCodeConverter.Instance}}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

  </StackPanel>

</UserControl>
