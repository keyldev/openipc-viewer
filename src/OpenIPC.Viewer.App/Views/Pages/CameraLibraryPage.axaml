<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenIPC.Viewer.App.ViewModels"
             xmlns:svc="using:OpenIPC.Viewer.App.Services"
             x:Class="OpenIPC.Viewer.App.Views.Pages.CameraLibraryPage"
             x:DataType="vm:CameraLibraryPageViewModel">
  <Grid RowDefinitions="Auto,*">

    <!-- Header. Title on top, actions wrap below so a narrow viewport (phone
         or pinned-narrow desktop) doesn't shove buttons off-screen. -->
    <StackPanel Grid.Row="0" Spacing="12" Margin="0,0,0,16">
      <TextBlock Text="{Binding [Library.Title], Source={x:Static svc:Localizer.Instance}}"
                 FontSize="{StaticResource FontSizeXl}"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextPrimaryBrush}" />
      <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="8">
        <ComboBox ItemsSource="{Binding AvailableGroups}"
                  SelectedItem="{Binding SelectedGroupFilter, Mode=TwoWay}"
                  MinWidth="160"
                  PlaceholderText="{Binding [Library.AllGroups], Source={x:Static svc:Localizer.Instance}}">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name, FallbackValue='', TargetNullValue=''}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Content="{Binding [Library.ManageGroups], Source={x:Static svc:Localizer.Instance}}"
                Command="{Binding ManageGroupsCommand}"
                Padding="14,8"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Foreground="{StaticResource TextPrimaryBrush}" />
        <Button Content="{Binding [Common.Refresh], Source={x:Static svc:Localizer.Instance}}"
                Command="{Binding RefreshCommand}"
                Padding="14,8"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Foreground="{StaticResource TextPrimaryBrush}" />
        <Button Content="{Binding [Common.Discover], Source={x:Static svc:Localizer.Instance}}"
                Command="{Binding DiscoverCameraCommand}"
                Padding="14,8"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Foreground="{StaticResource TextPrimaryBrush}" />
        <Button Content="{Binding [Library.ScanQr], Source={x:Static svc:Localizer.Instance}}"
                Command="{Binding ScanQrCommand}"
                Padding="14,8"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Foreground="{StaticResource TextPrimaryBrush}" />
        <Button Content="{Binding [Common.AddCamera], Source={x:Static svc:Localizer.Instance}}"
                Command="{Binding AddCameraCommand}"
                Padding="14,8"
                Background="{StaticResource AccentBrush}"
                Foreground="White"
                CornerRadius="8" />
      </WrapPanel>
    </StackPanel>

    <!-- Empty state -->
    <StackPanel Grid.Row="1"
                IsVisible="{Binding IsEmpty}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="12">
      <TextBlock Text="{Binding [Library.EmptyTitle], Source={x:Static svc:Localizer.Instance}}"
                 FontSize="{StaticResource FontSizeLg}"
                 Foreground="{StaticResource TextSecondaryBrush}"
                 HorizontalAlignment="Center" />
      <Button Content="{Binding [Common.AddCamera], Source={x:Static svc:Localizer.Instance}}"
              Command="{Binding AddCameraCommand}"
              Padding="14,8"
              Background="{StaticResource AccentBrush}"
              Foreground="White"
              CornerRadius="8"
              HorizontalAlignment="Center" />
    </StackPanel>

    <!-- List -->
    <ScrollViewer Grid.Row="1" IsVisible="{Binding HasCameras}">
      <ItemsControl ItemsSource="{Binding Cameras}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="12" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:CameraRowViewModel">
            <Border Background="{StaticResource Bg2Brush}"
                    BorderBrush="{StaticResource BorderWeakBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16"
                    Cursor="Hand"
                    Tapped="OnCameraCardTapped">
              <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">

                <Border Grid.Column="0" Grid.RowSpan="2"
                        Width="96" Height="64"
                        Background="{StaticResource Bg0Brush}"
                        CornerRadius="6"
                        Margin="0,0,16,0">
                  <TextBlock Text="cam"
                             FontFamily="{StaticResource FontMono}"
                             FontSize="{StaticResource FontSizeSm}"
                             Foreground="{StaticResource TextTertiaryBrush}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Border>

                <TextBlock Grid.Column="1" Grid.Row="0"
                           Text="{Binding Name}"
                           FontSize="{StaticResource FontSizeMd}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />

                <StackPanel Grid.Column="1" Grid.Row="1"
                            Orientation="Horizontal"
                            Spacing="10"
                            Margin="0,4,0,0">
                  <TextBlock Text="{Binding HostAndPort}"
                             FontFamily="{StaticResource FontMono}"
                             FontSize="{StaticResource FontSizeSm}"
                             Foreground="{StaticResource TextSecondaryBrush}" />
                  <Border Background="{StaticResource Bg3Brush}"
                          CornerRadius="3"
                          Padding="6,2">
                    <TextBlock Text="{Binding [Library.Offline], Source={x:Static svc:Localizer.Instance}}"
                               FontFamily="{StaticResource FontMono}"
                               FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}" />
                  </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.RowSpan="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                  <CheckBox IsChecked="{Binding IsIncludedInGrid, Mode=TwoWay}"
                            Content="{Binding [Library.RowShowInGrid], Source={x:Static svc:Localizer.Instance}}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="{StaticResource FontSizeSm}"
                            VerticalAlignment="Center" />
                  <Button Content="{Binding [Library.RowEdit], Source={x:Static svc:Localizer.Instance}}"
                          Padding="10,6"
                          Background="Transparent"
                          BorderBrush="{StaticResource BorderMediumBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Command="{Binding $parent[ItemsControl].((vm:CameraLibraryPageViewModel)DataContext).EditCameraCommand}"
                          CommandParameter="{Binding}" />
                  <Button Content="{Binding [Library.RowDelete], Source={x:Static svc:Localizer.Instance}}"
                          Padding="10,6"
                          Background="Transparent"
                          BorderBrush="{StaticResource BorderMediumBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          Foreground="{StaticResource DangerBrush}"
                          Command="{Binding $parent[ItemsControl].((vm:CameraLibraryPageViewModel)DataContext).DeleteCameraCommand}"
                          CommandParameter="{Binding}" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </Grid>
</UserControl>
