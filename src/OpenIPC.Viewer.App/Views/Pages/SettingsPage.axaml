<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenIPC.Viewer.App.ViewModels"
             xmlns:svc="using:OpenIPC.Viewer.App.Services"
             xmlns:conv="using:OpenIPC.Viewer.App.Converters"
             x:Class="OpenIPC.Viewer.App.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsPageViewModel">

  <UserControl.Styles>
    <!-- Section card kept for any future "feature card" — fields below use
         the bare Grid + label layout, no card wrapper, so detail looks like
         macOS Settings (flat with section header). -->
    <Style Selector="Path.section-icon">
      <Setter Property="Width" Value="22" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Stroke" Value="{StaticResource AccentBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="{StaticResource FontSizeLg}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.field-label">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Margin" Value="0,0,12,0" />
    </Style>
    <Style Selector="Button.outlined">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderMediumBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
    <!-- Sidebar / list ListBox: flat tiles, accent on selection. -->
    <Style Selector="ListBox.sections">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.sections ListBoxItem">
      <Setter Property="Padding" Value="10,10" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Margin" Value="0,2" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <!-- Per-item Lucide icon stroke colour mirrors the row's foreground so it
         flips to white on the selected/accent state automatically. -->
    <Style Selector="ListBox.sections Path.tile-icon">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="Stroke" Value="{StaticResource AccentBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="ListBox.sections ListBoxItem:selected Path.tile-icon">
      <Setter Property="Stroke" Value="White" />
    </Style>
    <Style Selector="ListBox.sections Path.tile-chevron">
      <Setter Property="Width" Value="14" />
      <Setter Property="Height" Value="14" />
      <Setter Property="Stroke" Value="{StaticResource TextTertiaryBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.back-link">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0,4" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
  </UserControl.Styles>

  <Grid x:Name="RootGrid">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="0" />
    </Grid.ColumnDefinitions>

    <!-- ===== Master / list pane (column 0) ===== -->
    <ScrollViewer Grid.Column="0"
                  IsVisible="{Binding ShowList}"
                  Padding="0,0,8,24"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.Title], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeXl}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,4" />

        <ListBox Classes="sections"
                 SelectedIndex="{Binding SelectedSectionIndex, Mode=TwoWay}">
          <ListBoxItem>
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Path Grid.Column="0" Classes="lucide tile-icon"
                    Data="{StaticResource IconAppearance}"
                    Margin="0,0,12,0" />
              <TextBlock Grid.Column="1"
                         Text="{Binding [Settings.Appearance], Source={x:Static svc:Localizer.Instance}}"
                         VerticalAlignment="Center" />
              <Path Grid.Column="2" Classes="lucide tile-chevron"
                    Data="{StaticResource IconChevronRight}"
                    IsVisible="{Binding !IsWide}" />
            </Grid>
          </ListBoxItem>
          <ListBoxItem>
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Path Grid.Column="0" Classes="lucide tile-icon"
                    Data="{StaticResource IconVideo}"
                    Margin="0,0,12,0" />
              <TextBlock Grid.Column="1"
                         Text="{Binding [Settings.Video], Source={x:Static svc:Localizer.Instance}}"
                         VerticalAlignment="Center" />
              <Path Grid.Column="2" Classes="lucide tile-chevron"
                    Data="{StaticResource IconChevronRight}"
                    IsVisible="{Binding !IsWide}" />
            </Grid>
          </ListBoxItem>
          <ListBoxItem>
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Path Grid.Column="0" Classes="lucide tile-icon"
                    Data="{StaticResource IconRecord}"
                    Margin="0,0,12,0" />
              <TextBlock Grid.Column="1"
                         Text="{Binding [Settings.Recording], Source={x:Static svc:Localizer.Instance}}"
                         VerticalAlignment="Center" />
              <Path Grid.Column="2" Classes="lucide tile-chevron"
                    Data="{StaticResource IconChevronRight}"
                    IsVisible="{Binding !IsWide}" />
            </Grid>
          </ListBoxItem>
          <ListBoxItem>
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Path Grid.Column="0" Classes="lucide tile-icon"
                    Data="{StaticResource IconRadar}"
                    Margin="0,0,12,0" />
              <TextBlock Grid.Column="1"
                         Text="{Binding [Settings.Discovery], Source={x:Static svc:Localizer.Instance}}"
                         VerticalAlignment="Center" />
              <Path Grid.Column="2" Classes="lucide tile-chevron"
                    Data="{StaticResource IconChevronRight}"
                    IsVisible="{Binding !IsWide}" />
            </Grid>
          </ListBoxItem>
          <ListBoxItem>
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Path Grid.Column="0" Classes="lucide tile-icon"
                    Data="{StaticResource IconAdvanced}"
                    Margin="0,0,12,0" />
              <TextBlock Grid.Column="1"
                         Text="{Binding [Settings.Advanced], Source={x:Static svc:Localizer.Instance}}"
                         VerticalAlignment="Center" />
              <Path Grid.Column="2" Classes="lucide tile-chevron"
                    Data="{StaticResource IconChevronRight}"
                    IsVisible="{Binding !IsWide}" />
            </Grid>
          </ListBoxItem>
          <ListBoxItem>
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Path Grid.Column="0" Classes="lucide tile-icon"
                    Data="{StaticResource IconAbout}"
                    Margin="0,0,12,0" />
              <TextBlock Grid.Column="1"
                         Text="{Binding [Settings.About], Source={x:Static svc:Localizer.Instance}}"
                         VerticalAlignment="Center" />
              <Path Grid.Column="2" Classes="lucide tile-chevron"
                    Data="{StaticResource IconChevronRight}"
                    IsVisible="{Binding !IsWide}" />
            </Grid>
          </ListBoxItem>
        </ListBox>
      </StackPanel>
    </ScrollViewer>

    <!-- ===== Detail pane (column 1) ===== -->
    <ScrollViewer Grid.Column="1"
                  IsVisible="{Binding ShowDetail}"
                  Padding="16,0,8,24"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="20">

        <!-- Back link — narrow only -->
        <Button Classes="back-link"
                IsVisible="{Binding ShowBackButton}"
                Command="{Binding BackToListCommand}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Classes="lucide" Data="{StaticResource IconChevronLeft}"
                  Stroke="{StaticResource TextSecondaryBrush}"
                  Width="16" Height="16" VerticalAlignment="Center" />
            <TextBlock Text="{Binding [Settings.Title], Source={x:Static svc:Localizer.Instance}}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Appearance -->
        <StackPanel IsVisible="{Binding IsAppearance}" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Path Classes="lucide section-icon" Data="{StaticResource IconAppearance}" />
            <TextBlock Classes="section-title"
                       Text="{Binding [Settings.Appearance], Source={x:Static svc:Localizer.Instance}}" />
          </StackPanel>

          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Classes="field-label"
                       Text="{Binding [Settings.Appearance.Language], Source={x:Static svc:Localizer.Instance}}" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding LanguageOptions}"
                      SelectedItem="{Binding Language, Mode=TwoWay}"
                      MinWidth="140">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <TextBlock Text="{Binding ., Converter={x:Static conv:LanguageCodeConverter.Instance}}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </StackPanel>

        <!-- Video -->
        <StackPanel IsVisible="{Binding IsVideo}" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Path Classes="lucide section-icon" Data="{StaticResource IconVideo}" />
            <TextBlock Classes="section-title"
                       Text="{Binding [Settings.Video], Source={x:Static svc:Localizer.Instance}}" />
          </StackPanel>

          <CheckBox IsChecked="{Binding ShowTelemetryOverlay}"
                    Content="{Binding [Settings.Video.TelemetryOverlay], Source={x:Static svc:Localizer.Instance}}"
                    Foreground="{StaticResource TextPrimaryBrush}" />

          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Classes="field-label"
                       Text="{Binding [Settings.Video.MaxGridSessions], Source={x:Static svc:Localizer.Instance}}" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding GridSessionOptions}"
                      SelectedItem="{Binding MaxConcurrentGridSessions, Mode=TwoWay}"
                      MinWidth="80" />
          </Grid>

          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Classes="field-label"
                       Text="{Binding [Settings.Video.RtspTransport], Source={x:Static svc:Localizer.Instance}}" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding TransportOptions}"
                      SelectedItem="{Binding RtspTransport, Mode=TwoWay}"
                      MinWidth="80" />
          </Grid>
        </StackPanel>

        <!-- Recording -->
        <StackPanel IsVisible="{Binding IsRecording}" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Path Classes="lucide section-icon" Data="{StaticResource IconRecord}" />
            <TextBlock Classes="section-title"
                       Text="{Binding [Settings.Recording], Source={x:Static svc:Localizer.Instance}}" />
          </StackPanel>

          <StackPanel Spacing="8">
            <TextBlock Classes="field-label"
                       Text="{Binding [Settings.Recording.Directory], Source={x:Static svc:Localizer.Instance}}" />
            <TextBox Text="{Binding EffectiveRecordingsDirectory, Mode=OneWay}"
                     IsReadOnly="True"
                     FontFamily="{StaticResource FontMono}"
                     FontSize="{StaticResource FontSizeSm}"
                     Background="{StaticResource Bg0Brush}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     BorderBrush="{StaticResource BorderWeakBrush}" />
            <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="6" Margin="0,2,0,0">
              <Button Classes="outlined"
                      Content="{Binding [Settings.Recording.PickFolder], Source={x:Static svc:Localizer.Instance}}"
                      Command="{Binding PickRecordingsDirectoryCommand}" />
              <Button Classes="outlined"
                      Content="{Binding [Settings.Recording.Reset], Source={x:Static svc:Localizer.Instance}}"
                      Command="{Binding ResetRecordingsDirectoryCommand}"
                      IsVisible="{Binding IsRecordingsDirOverridden}"
                      Foreground="{StaticResource TextSecondaryBrush}" />
              <Button Classes="outlined"
                      Content="{Binding [Settings.Recording.Open], Source={x:Static svc:Localizer.Instance}}"
                      Command="{Binding OpenRecordingsDirectoryCommand}" />
            </WrapPanel>
          </StackPanel>
        </StackPanel>

        <!-- Discovery -->
        <StackPanel IsVisible="{Binding IsDiscovery}" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Path Classes="lucide section-icon" Data="{StaticResource IconRadar}" />
            <TextBlock Classes="section-title"
                       Text="{Binding [Settings.Discovery], Source={x:Static svc:Localizer.Instance}}" />
          </StackPanel>

          <CheckBox IsChecked="{Binding AutoScanLanOnStartup}"
                    Content="{Binding [Settings.Discovery.AutoScan], Source={x:Static svc:Localizer.Instance}}"
                    Foreground="{StaticResource TextPrimaryBrush}" />
        </StackPanel>

        <!-- Advanced -->
        <StackPanel IsVisible="{Binding IsAdvanced}" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Path Classes="lucide section-icon" Data="{StaticResource IconAdvanced}" />
            <TextBlock Classes="section-title"
                       Text="{Binding [Settings.Advanced], Source={x:Static svc:Localizer.Instance}}" />
          </StackPanel>

          <CheckBox IsChecked="{Binding VerboseLogging}"
                    Content="{Binding [Settings.Advanced.VerboseLogging], Source={x:Static svc:Localizer.Instance}}"
                    Foreground="{StaticResource TextPrimaryBrush}" />

          <CheckBox IsChecked="{Binding RawConfigEditorEnabled}"
                    Content="{Binding [Settings.Advanced.RawConfigEditor], Source={x:Static svc:Localizer.Instance}}"
                    Foreground="{StaticResource TextPrimaryBrush}" />

          <StackPanel Spacing="6">
            <Button Classes="outlined"
                    Content="{Binding [Settings.Advanced.OpenAppData], Source={x:Static svc:Localizer.Instance}}"
                    Command="{Binding OpenAppDataDirectoryCommand}"
                    HorizontalAlignment="Left" />
            <TextBlock Text="{Binding AppDataDirectory}"
                       FontFamily="{StaticResource FontMono}"
                       FontSize="{StaticResource FontSizeSm}"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </StackPanel>

        <!-- About -->
        <StackPanel IsVisible="{Binding IsAbout}" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Path Classes="lucide section-icon" Data="{StaticResource IconAbout}" />
            <TextBlock Classes="section-title"
                       Text="{Binding [Settings.About], Source={x:Static svc:Localizer.Instance}}" />
          </StackPanel>

          <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="OpenIPC Viewer " />
            <Run Text="{Binding Version}" />
          </TextBlock>

          <Button Classes="outlined"
                  Content="{Binding [Settings.About.Repository], Source={x:Static svc:Localizer.Instance}}"
                  Command="{Binding OpenRepositoryCommand}"
                  HorizontalAlignment="Left" />
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

  </Grid>

</UserControl>
