<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenIPC.Viewer.App.ViewModels"
             xmlns:svc="using:OpenIPC.Viewer.App.Services"
             x:Class="OpenIPC.Viewer.App.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsPageViewModel">

  <ScrollViewer>
    <StackPanel Spacing="24" Margin="0,0,8,24" VerticalAlignment="Top">

      <TextBlock Text="{Binding [Settings.Title], Source={x:Static svc:Localizer.Instance}}"
                 FontSize="{StaticResource FontSizeXl}"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextPrimaryBrush}" />

      <!-- Appearance -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.Appearance], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="{Binding [Settings.Appearance.Language], Source={x:Static svc:Localizer.Instance}}"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource TextSecondaryBrush}" />
          <ComboBox ItemsSource="{Binding LanguageOptions}"
                    SelectedItem="{Binding Language, Mode=TwoWay}"
                    MinWidth="120" />
        </StackPanel>
      </StackPanel>

      <!-- Video -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.Video], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <CheckBox IsChecked="{Binding ShowTelemetryOverlay}"
                  Content="Show telemetry overlay on live view"
                  Foreground="{StaticResource TextPrimaryBrush}" />

        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="Max concurrent grid sessions"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource TextSecondaryBrush}" />
          <ComboBox ItemsSource="{Binding GridSessionOptions}"
                    SelectedItem="{Binding MaxConcurrentGridSessions, Mode=TwoWay}"
                    MinWidth="80" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="Default RTSP transport"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource TextSecondaryBrush}" />
          <ComboBox ItemsSource="{Binding TransportOptions}"
                    SelectedItem="{Binding RtspTransport, Mode=TwoWay}"
                    MinWidth="80" />
        </StackPanel>
      </StackPanel>

      <!-- Recording -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.Recording], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <StackPanel Spacing="4">
          <TextBlock Text="Recordings directory"
                     Foreground="{StaticResource TextSecondaryBrush}" />
          <TextBox Text="{Binding EffectiveRecordingsDirectory, Mode=OneWay}"
                   IsReadOnly="True"
                   FontFamily="{StaticResource FontMono}"
                   FontSize="{StaticResource FontSizeSm}"
                   Background="{StaticResource Bg2Brush}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   BorderBrush="{StaticResource BorderWeakBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Pick folder…"
                    Command="{Binding PickRecordingsDirectoryCommand}"
                    Background="Transparent"
                    BorderBrush="{StaticResource BorderMediumBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6"
                    Foreground="{StaticResource TextPrimaryBrush}" />
            <Button Content="Reset to default"
                    Command="{Binding ResetRecordingsDirectoryCommand}"
                    IsVisible="{Binding IsRecordingsDirOverridden}"
                    Background="Transparent"
                    BorderBrush="{StaticResource BorderMediumBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6"
                    Foreground="{StaticResource TextSecondaryBrush}" />
            <Button Content="Open"
                    Command="{Binding OpenRecordingsDirectoryCommand}"
                    Background="Transparent"
                    BorderBrush="{StaticResource BorderMediumBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6"
                    Foreground="{StaticResource TextPrimaryBrush}" />
          </StackPanel>
        </StackPanel>
      </StackPanel>

      <!-- Discovery -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.Discovery], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <CheckBox IsChecked="{Binding AutoScanLanOnStartup}"
                  Content="Run WS-Discovery on launch"
                  Foreground="{StaticResource TextPrimaryBrush}" />
      </StackPanel>

      <!-- Advanced -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.Advanced], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <CheckBox IsChecked="{Binding VerboseLogging}"
                  Content="Verbose logging (debug level)"
                  Foreground="{StaticResource TextPrimaryBrush}" />

        <Button Content="Open app data folder"
                Command="{Binding OpenAppDataDirectoryCommand}"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,6"
                Foreground="{StaticResource TextPrimaryBrush}"
                HorizontalAlignment="Left" />

        <TextBlock Text="{Binding AppDataDirectory}"
                   FontFamily="{StaticResource FontMono}"
                   FontSize="{StaticResource FontSizeSm}"
                   Foreground="{StaticResource TextTertiaryBrush}" />
      </StackPanel>

      <!-- About -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.About], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
          <Run Text="OpenIPC Viewer " />
          <Run Text="{Binding Version}" />
        </TextBlock>

        <Button Content="GitHub repository →"
                Command="{Binding OpenRepositoryCommand}"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,6"
                Foreground="{StaticResource TextPrimaryBrush}"
                HorizontalAlignment="Left" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>

</UserControl>
