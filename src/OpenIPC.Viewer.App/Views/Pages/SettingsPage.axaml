<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenIPC.Viewer.App.ViewModels"
             xmlns:svc="using:OpenIPC.Viewer.App.Services"
             x:Class="OpenIPC.Viewer.App.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsPageViewModel">

  <ScrollViewer>
    <StackPanel Spacing="24" Margin="0,0,8,24" VerticalAlignment="Top">

      <TextBlock Text="{Binding [Settings.Title], Source={x:Static svc:Localizer.Instance}}"
                 FontSize="{StaticResource FontSizeXl}"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextPrimaryBrush}" />

      <!-- Appearance -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.Appearance], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="{Binding [Settings.Appearance.Language], Source={x:Static svc:Localizer.Instance}}"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource TextSecondaryBrush}" />
          <ComboBox ItemsSource="{Binding LanguageOptions}"
                    SelectedItem="{Binding Language, Mode=TwoWay}"
                    MinWidth="120" />
        </StackPanel>
      </StackPanel>

      <!-- Video -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.Video], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <CheckBox IsChecked="{Binding ShowTelemetryOverlay}"
                  Content="{Binding [Settings.Video.TelemetryOverlay], Source={x:Static svc:Localizer.Instance}}"
                  Foreground="{StaticResource TextPrimaryBrush}" />

        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="{Binding [Settings.Video.MaxGridSessions], Source={x:Static svc:Localizer.Instance}}"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource TextSecondaryBrush}" />
          <ComboBox ItemsSource="{Binding GridSessionOptions}"
                    SelectedItem="{Binding MaxConcurrentGridSessions, Mode=TwoWay}"
                    MinWidth="80" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="{Binding [Settings.Video.RtspTransport], Source={x:Static svc:Localizer.Instance}}"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource TextSecondaryBrush}" />
          <ComboBox ItemsSource="{Binding TransportOptions}"
                    SelectedItem="{Binding RtspTransport, Mode=TwoWay}"
                    MinWidth="80" />
        </StackPanel>
      </StackPanel>

      <!-- Recording -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.Recording], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <StackPanel Spacing="4">
          <TextBlock Text="{Binding [Settings.Recording.Directory], Source={x:Static svc:Localizer.Instance}}"
                     Foreground="{StaticResource TextSecondaryBrush}" />
          <TextBox Text="{Binding EffectiveRecordingsDirectory, Mode=OneWay}"
                   IsReadOnly="True"
                   FontFamily="{StaticResource FontMono}"
                   FontSize="{StaticResource FontSizeSm}"
                   Background="{StaticResource Bg2Brush}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   BorderBrush="{StaticResource BorderWeakBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{Binding [Settings.Recording.PickFolder], Source={x:Static svc:Localizer.Instance}}"
                    Command="{Binding PickRecordingsDirectoryCommand}"
                    Background="Transparent"
                    BorderBrush="{StaticResource BorderMediumBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6"
                    Foreground="{StaticResource TextPrimaryBrush}" />
            <Button Content="{Binding [Settings.Recording.Reset], Source={x:Static svc:Localizer.Instance}}"
                    Command="{Binding ResetRecordingsDirectoryCommand}"
                    IsVisible="{Binding IsRecordingsDirOverridden}"
                    Background="Transparent"
                    BorderBrush="{StaticResource BorderMediumBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6"
                    Foreground="{StaticResource TextSecondaryBrush}" />
            <Button Content="{Binding [Settings.Recording.Open], Source={x:Static svc:Localizer.Instance}}"
                    Command="{Binding OpenRecordingsDirectoryCommand}"
                    Background="Transparent"
                    BorderBrush="{StaticResource BorderMediumBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6"
                    Foreground="{StaticResource TextPrimaryBrush}" />
          </StackPanel>
        </StackPanel>
      </StackPanel>

      <!-- Discovery -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.Discovery], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <CheckBox IsChecked="{Binding AutoScanLanOnStartup}"
                  Content="{Binding [Settings.Discovery.AutoScan], Source={x:Static svc:Localizer.Instance}}"
                  Foreground="{StaticResource TextPrimaryBrush}" />
      </StackPanel>

      <!-- Advanced -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.Advanced], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <CheckBox IsChecked="{Binding VerboseLogging}"
                  Content="{Binding [Settings.Advanced.VerboseLogging], Source={x:Static svc:Localizer.Instance}}"
                  Foreground="{StaticResource TextPrimaryBrush}" />

        <CheckBox IsChecked="{Binding RawConfigEditorEnabled}"
                  Content="{Binding [Settings.Advanced.RawConfigEditor], Source={x:Static svc:Localizer.Instance}}"
                  Foreground="{StaticResource TextPrimaryBrush}" />

        <Button Content="{Binding [Settings.Advanced.OpenAppData], Source={x:Static svc:Localizer.Instance}}"
                Command="{Binding OpenAppDataDirectoryCommand}"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,6"
                Foreground="{StaticResource TextPrimaryBrush}"
                HorizontalAlignment="Left" />

        <TextBlock Text="{Binding AppDataDirectory}"
                   FontFamily="{StaticResource FontMono}"
                   FontSize="{StaticResource FontSizeSm}"
                   Foreground="{StaticResource TextTertiaryBrush}" />
      </StackPanel>

      <!-- About -->
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding [Settings.About], Source={x:Static svc:Localizer.Instance}}"
                   FontSize="{StaticResource FontSizeMd}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
          <Run Text="OpenIPC Viewer " />
          <Run Text="{Binding Version}" />
        </TextBlock>

        <Button Content="{Binding [Settings.About.Repository], Source={x:Static svc:Localizer.Instance}}"
                Command="{Binding OpenRepositoryCommand}"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,6"
                Foreground="{StaticResource TextPrimaryBrush}"
                HorizontalAlignment="Left" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>

</UserControl>
