<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenIPC.Viewer.App.ViewModels"
             xmlns:controls="using:OpenIPC.Viewer.App.Controls"
             x:Class="OpenIPC.Viewer.App.Views.Pages.SingleCameraPage"
             x:DataType="vm:SingleCameraPageViewModel">

  <Grid RowDefinitions="Auto,*,Auto,Auto">

    <!-- Header -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
      <Button Grid.Column="0"
              Content="← Back"
              Command="{Binding BackCommand}"
              Background="Transparent"
              BorderBrush="{StaticResource BorderMediumBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="10,6"
              Foreground="{StaticResource TextPrimaryBrush}" />
      <StackPanel Grid.Column="1" Spacing="2" Margin="16,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="{Binding CameraName}"
                   FontSize="{StaticResource FontSizeLg}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />
        <TextBlock Text="{Binding HostLabel}"
                   FontFamily="{StaticResource FontMono}"
                   FontSize="{StaticResource FontSizeSm}"
                   Foreground="{StaticResource TextSecondaryBrush}" />
      </StackPanel>
    </Grid>

    <!-- Video + overlays -->
    <Grid Grid.Row="1">
      <controls:RtspVideoView Session="{Binding Session}" />

      <!-- Top-left LIVE badge -->
      <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12"
              Background="{StaticResource DangerBrush}"
              CornerRadius="3"
              Padding="6,2"
              IsVisible="{Binding Session, Converter={x:Static ObjectConverters.IsNotNull}}">
        <TextBlock Text="LIVE" FontFamily="{StaticResource FontMono}" FontSize="10" Foreground="White" />
      </Border>

      <!-- Top-right resolution/codec -->
      <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12"
              Background="#80000000"
              CornerRadius="3"
              Padding="6,2"
              IsVisible="{Binding Telemetry, Converter={x:Static ObjectConverters.IsNotNull}}">
        <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}">
          <Run Text="{Binding Telemetry.Width}" /><Run Text="x" /><Run Text="{Binding Telemetry.Height}" /><Run Text=" " /><Run Text="{Binding Telemetry.Codec}" />
        </TextBlock>
      </Border>

      <!-- Bottom-left fps -->
      <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12"
              Background="#80000000"
              CornerRadius="3"
              Padding="6,2"
              IsVisible="{Binding Telemetry, Converter={x:Static ObjectConverters.IsNotNull}}">
        <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}">
          <Run Text="{Binding Telemetry.Fps, StringFormat={}{0:F0} fps}" />
        </TextBlock>
      </Border>

      <!-- Bottom-right frames -->
      <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12"
              Background="#80000000"
              CornerRadius="3"
              Padding="6,2"
              IsVisible="{Binding Telemetry, Converter={x:Static ObjectConverters.IsNotNull}}">
        <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}">
          <Run Text="{Binding Telemetry.FramesDecoded}" /><Run Text=" frames" />
        </TextBlock>
      </Border>

      <!-- Error overlay -->
      <Border HorizontalAlignment="Stretch" VerticalAlignment="Top"
              Background="{StaticResource DangerBrush}"
              Padding="12,8"
              IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Text="{Binding ErrorMessage}" Foreground="White" />
      </Border>

      <!-- PTZ overlay (joystick + presets), bottom-right, only for PTZ cams -->
      <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                  Margin="0,0,12,48" Spacing="10"
                  IsVisible="{Binding HasPtz}">
        <controls:PtzJoystick Controller="{Binding Ptz}" HorizontalAlignment="Right" />

        <Border Background="#90000000" CornerRadius="6" Padding="8" MaxWidth="280">
          <StackPanel Spacing="6">
            <ItemsControl ItemsSource="{Binding Presets}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="2" ColumnDefinitions="Auto,Auto">
                    <Button Grid.Column="0"
                            Content="{Binding Name}"
                            Padding="8,4"
                            Background="{StaticResource Bg2Brush}"
                            Foreground="White"
                            CornerRadius="4"
                            FontSize="11"
                            Command="{Binding $parent[ItemsControl].((vm:SingleCameraPageViewModel)DataContext).GotoPresetCommand}"
                            CommandParameter="{Binding}" />
                    <Button Grid.Column="1"
                            Content="✕"
                            Padding="6,4"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="11"
                            Command="{Binding $parent[ItemsControl].((vm:SingleCameraPageViewModel)DataContext).RemovePresetCommand}"
                            CommandParameter="{Binding}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Grid ColumnDefinitions="*,Auto" Margin="2,4,2,2">
              <TextBox Grid.Column="0"
                       Text="{Binding NewPresetName, Mode=TwoWay}"
                       PlaceholderText="preset name"
                       FontSize="11"
                       Padding="6,4"
                       Margin="0,0,4,0" />
              <Button Grid.Column="1"
                      Content="+ Save"
                      Command="{Binding SavePresetCommand}"
                      Padding="8,4"
                      Background="{StaticResource AccentBrush}"
                      Foreground="White"
                      CornerRadius="4"
                      FontSize="11" />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>

    <!-- Majestic Config panel (Phase 5) — only for OpenIPC-Majestic cameras -->
    <Border Grid.Row="2"
            Margin="0,12,0,0"
            Padding="14,10"
            Background="{StaticResource Bg2Brush}"
            BorderBrush="{StaticResource BorderWeakBrush}"
            BorderThickness="1"
            CornerRadius="8"
            IsVisible="{Binding IsMajestic}">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">

        <!-- Title + info row -->
        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
          <TextBlock Text="Majestic"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     VerticalAlignment="Center" />
          <TextBlock VerticalAlignment="Center"
                     FontFamily="{StaticResource FontMono}"
                     FontSize="{StaticResource FontSizeSm}"
                     Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="{Binding MajesticConfig.Resolution, FallbackValue='?'}" />
            <Run Text="·" />
            <Run Text="{Binding MajesticConfig.Codec, FallbackValue='?'}" />
            <Run Text="·" />
            <Run Text="{Binding MajesticConfig.Fps, FallbackValue='?'}" /><Run Text=" fps" />
            <Run Text="·" />
            <Run Text="{Binding MajesticConfig.Bitrate, FallbackValue='?'}" /><Run Text=" kbps" />
          </TextBlock>
        </StackPanel>

        <!-- Night mode buttons -->
        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Spacing="4">
          <Button Content="Day"
                  Command="{Binding SetNightModeCommand}" CommandParameter="day"
                  Padding="10,4" FontSize="11"
                  Background="{StaticResource Bg3Brush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  CornerRadius="4" />
          <Button Content="Night"
                  Command="{Binding SetNightModeCommand}" CommandParameter="night"
                  Padding="10,4" FontSize="11"
                  Background="{StaticResource Bg3Brush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  CornerRadius="4" />
          <Button Content="Auto"
                  Command="{Binding SetNightModeCommand}" CommandParameter="auto"
                  Padding="10,4" FontSize="11"
                  Background="{StaticResource Bg3Brush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  CornerRadius="4" />
        </StackPanel>

        <!-- Info + error row -->
        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                    Orientation="Horizontal" Spacing="10" Margin="0,6,0,0"
                    IsVisible="{Binding MajesticInfo, Converter={x:Static ObjectConverters.IsNotNull}}">
          <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
            <Run Text="{Binding MajesticInfo.Model, FallbackValue='?'}" />
            <Run Text="·" />
            <Run Text="{Binding MajesticInfo.FirmwareVersion, FallbackValue='?'}" />
            <Run Text="·" />
            <Run Text="night:" />
            <Run Text="{Binding CurrentNightMode}" />
          </TextBlock>
          <TextBlock Text="{Binding MajesticError}"
                     FontSize="11"
                     Foreground="{StaticResource DangerBrush}"
                     IsVisible="{Binding MajesticError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

      </Grid>
    </Border>

    <!-- Bottom bar -->
    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
      <TextBlock Grid.Column="0"
                 Text="{Binding SnapshotPath, StringFormat='Snapshot saved to {0}'}"
                 IsVisible="{Binding SnapshotPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                 Foreground="{StaticResource TextSecondaryBrush}"
                 FontSize="{StaticResource FontSizeSm}"
                 VerticalAlignment="Center" />
      <Button Grid.Column="1"
              Content="Snapshot"
              Command="{Binding SnapshotCommand}"
              Background="{StaticResource AccentBrush}"
              Foreground="White"
              Padding="14,8"
              CornerRadius="6" />
    </Grid>

  </Grid>

</UserControl>
